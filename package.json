{
  "name": "@p-vbordei/relative-time",
  "version": "0.1.0",
  "description": "Format dates as relative phrases (\"2 hours ago\", \"in 3 days\") with smart unit selection. Wraps Intl.RelativeTimeFormat. Zero dependencies.",
  "keywords": [
    "relative",
    "time",
    "intl",
    "date",
    "humanize",
    "ago"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build"
  },
  "engines": {
    "node": ">=20"
  },
  "author": {
    "name": "Vlad Bordei",
    "email": "bordeivlad@gmail.com",
    "url": "https://github.com/p-vbordei"
  },
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/p-vbordei/relative-time.git"
  },
  "bugs": {
    "url": "https://github.com/p-vbordei/relative-time/issues"
  },
  "homepage": "https://github.com/p-vbordei/relative-time#readme",
  "devDependencies": {
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  }
}
